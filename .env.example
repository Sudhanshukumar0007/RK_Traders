# ─────────────────────────────────────────────────────────────────────────────
# Supreme Hardware Store — Environment Variables Reference
# Copy this file to .env (backend) and .env.local (frontend) and fill in values.
# NEVER commit .env or .env.local to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# Async URL for SQLAlchemy (used by FastAPI)
DATABASE_URL=postgresql+asyncpg://supreme:supreme@localhost:5432/supreme_hardware
# Sync URL for Alembic migrations
DATABASE_URL_SYNC=postgresql://supreme:supreme@localhost:5432/supreme_hardware

# ── JWT Auth ──────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=your-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── App ───────────────────────────────────────────────────────────────────────
DEBUG=false
FRONTEND_URL=http://localhost:3000
UPLOAD_DIR=./uploads

# ── Phase 5: Shiprocket ───────────────────────────────────────────────────────
# Get from: https://app.shiprocket.in/api/user
SHIPROCKET_EMAIL=your-shiprocket-email@example.com
SHIPROCKET_PASSWORD=your-shiprocket-password

# ── Phase 6: Razorpay ─────────────────────────────────────────────────────────
# Get from: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
# Webhook secret from Razorpay dashboard > Webhooks
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret

# ── Frontend (.env.local) ─────────────────────────────────────────────────────
# These go in frontend/.env.local, NOT the backend .env
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
